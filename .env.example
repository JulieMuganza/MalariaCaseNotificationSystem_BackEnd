# PostgreSQL (localhost, default port 5432)
# Replace YOUR_PASSWORD with your postgres user password.
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/malaria_notification?schema=public"

# Server
PORT=3000
NODE_ENV=development
APP_BASE_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173

# JWT (use long random strings in production)
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_DAYS=30

# Password hashing
BCRYPT_ROUNDS=12

# Google OAuth placeholder (real OAuth not used in MVP)
GOOGLE_OAUTH_PLACEHOLDER_ISSUER=https://accounts.google.com

# Email (optional: if SMTP_HOST is empty, messages are printed to the API console)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false   (optional; port 587 forces STARTTLS, port 465 forces SSL)
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM="Malaria Case Notification <noreply@localhost>"
